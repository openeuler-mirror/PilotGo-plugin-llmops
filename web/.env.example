# Copy this file to `.env` (or `.env.local`) and adjust the values for your setup.
# The real `.env` file is git-ignored and must NOT be committed.

# Base URL used by the frontend HTTP client (src/apis/request.ts).
# Leave empty to issue same-origin relative requests (e.g. "/api"), which the
# Vite dev proxy below forwards to the backend. Set to an absolute URL
# (e.g. https://api.your-host.example) to call a remote API directly.
VITE_API_BASE_URL=

# Dev server only: backend that Vite proxies "/api" requests to.
# Defaults to http://localhost:8090 when unset.
VITE_DEV_PROXY_TARGET=http://localhost:8090
